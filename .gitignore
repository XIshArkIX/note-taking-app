# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# variant node_modules (each variant installs independently)
variants/*/node_modules/
variants/*/apps/*/node_modules/
variants/*/packages/*/node_modules/

# allow committed variant lockfiles and yarn config
!variants/*/bun.lock
!variants/*/package-lock.json
!variants/*/yarn.lock
!variants/*/pnpm-lock.yaml
!variants/*/.yarnrc.yml

# yarn variant: ignore install state but not the config files
variants/*/.yarn/install-state.gz
variants/*/.yarn/cache/

.pnpm-store